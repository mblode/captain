{
  "name": "cmux-captain",
  "version": "0.8.3",
  "description": "Drive a fleet of cmux worktrees through the SDLC, live — from Linear ticket to PR-ready",
  "keywords": [
    "captain",
    "cli",
    "cmux",
    "git",
    "linear",
    "orchestration",
    "worktree"
  ],
  "homepage": "https://github.com/mblode/captain#readme",
  "bugs": {
    "url": "https://github.com/mblode/captain/issues"
  },
  "license": "MIT",
  "author": "Matthew Blode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mblode/captain.git"
  },
  "bin": {
    "captain": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "npm run build && changeset publish",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt .",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.1.1",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tsdown": "^0.22.5",
    "typescript": "7.0.2",
    "ultracite": "7.9.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24"
  }
}
